# .env — NEVER commit this file to git!
# Copy to .env and fill in your values.

# ── AI APIs (free tiers) ──────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxxxx

# ── Job Source APIs (optional, more results) ──────
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key
RAPIDAPI_KEY=your_rapidapi_key

# ── Auto-Apply Credentials ────────────────────────
LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=your_password
INDEED_EMAIL=your@email.com

# Set to "false" to see the browser (useful for CAPTCHA debugging)
HEADLESS=true

# ── Google Sheets ─────────────────────────────────
GOOGLE_SHEETS_CREDS=credentials.json
SHEET_NAME=Job Automation Tracker

# ── Candidate Profile (override CONFIG in main.py) ─
CANDIDATE_NAME=Your Full Name
CANDIDATE_EMAIL=you@email.com
CANDIDATE_PHONE=+1-555-0100
CANDIDATE_SKILLS=Python,JavaScript,React,AWS,Docker
CANDIDATE_EXPERIENCE=3
SALARY_MIN=70000
SALARY_MAX=120000
BASE_RESUME=resume_base.docx

# ── Search Tuning ─────────────────────────────────
MIN_SCORE=40
MAX_APPLY=15

# ── Email Notifications (optional, Gmail example) ─
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
NOTIFY_EMAIL=you@gmail.com
